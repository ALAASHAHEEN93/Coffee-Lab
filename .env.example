# Where Neural Feed “SECURE” sends mail (mailto recipient). Public — safe to expose.
NEXT_PUBLIC_NEURAL_FEED_EMAIL=hello@yourdomain.com

# Payload + MongoDB (required for API: signup, admin, CMS)
# Local Docker: run `docker compose up -d` then use:
# DATABASE_URL=mongodb://127.0.0.1:27017/coffee-beans
# Atlas: use your SRV string from Atlas → Connect → Drivers
DATABASE_URL=
# Long random string (e.g. openssl rand -hex 32)
PAYLOAD_SECRET=

# Optional: Brevo API (only if you add server-side subscription again)
# BREVO_API_KEY=
# BREVO_NEURAL_FEED_LIST_ID=
